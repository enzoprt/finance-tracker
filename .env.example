# Copy this file to .env and fill in real values. .env is gitignored and must
# never be committed.

# --- Saxo Bank OpenAPI (developer.saxo) ---
# Environment: SIM for the simulation/paper-trading system, LIVE for real trading.
SAXO_ENVIRONMENT=SIM
SAXO_APP_KEY=
SAXO_APP_SECRET=
SAXO_REDIRECT_URI=http://localhost:8080/callback

# --- Enable Banking (enablebanking.com) ---
ENABLE_BANKING_APPLICATION_ID=
# Absolute path to the RSA private key (.pem) downloaded at app registration.
# Keep this file OUTSIDE the repo (e.g. in data/ or another private location);
# it is matched by .gitignore but there is no reason to place it under version
# control at all.
ENABLE_BANKING_PRIVATE_KEY_PATH=
ENABLE_BANKING_REDIRECT_URI=https://localhost:8080/callback

# Surname used to detect internal self-transfers (e.g. towards a Livret) in
# LCL/N26 transaction descriptions.
ACCOUNT_HOLDER_SURNAME=
